<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            style="@style/Widget.MaterialComponents.Toolbar.Primary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:menu="@menu/toolbar_neu"
            app:navigationIcon="@drawable/baseline_menu_black_24"
            app:title="@string/page_title" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/topMenu"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_margin="10dp"
        android:elevation="5dp"
        app:cardCornerRadius="10dp"
        app:layout_constraintBottom_toTopOf="@id/source_annotation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            >

            <ImageView
                android:layout_width="100dp"
                android:layout_height="160dp"
                android:contentDescription="Aliens move poster"
                android:scaleType="fitXY"
                android:src="@drawable/aliens_movie"
                android:layoutAnimation="@anim/poster_animation_layout"
                android:clickable="true"
                />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="160dp"
                android:contentDescription="Dark Knight move poster"
                android:scaleType="fitXY"
                android:src="@drawable/dark_knight_movie"
                android:layoutAnimation="@anim/poster_animation_layout"
                />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="160dp"
                android:contentDescription="Gladiator move poster"
                android:scaleType="fitXY"
                android:src="@drawable/gladiator_movie"
                android:layoutAnimation="@anim/poster_animation_layout"
                />

            <ImageView
                android:layout_width="100dp"
                android:layout_height="160dp"
                android:contentDescription="Top Gun move poster"
                android:scaleType="fitXY"
                android:scaleX="1"
                android:scaleY="1.02"
                android:src="@drawable/top_gun_movie2"
                android:layoutAnimation="@anim/poster_animation_layout" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/source_annotation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:autoLink="web"
        android:linksClickable="true"
        android:text="Source: https://www.movieposters.com"
        android:textColor="@color/light_gray"
        android:textStyle="bold"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topMenu" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#183525"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/toolbar_menu_for_navmenu" />

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:columnCount="2"
        android:orientation="horizontal"
        android:useDefaultMargins="true"
        android:layoutAnimation="@anim/layout_animation_on_start_animation"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/source_annotation"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="150dp"
            android:layout_height="200dp"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:stateListAnimator="@animator/poster_click_animator"
            android:contentDescription="A movie poster of civil war">

            <ImageView
                android:id="@+id/poster_warfare"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/warfare_poster1"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="150dp"
            android:layout_height="200dp"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:stateListAnimator="@animator/poster_click_animator"
            android:contentDescription="A movie poster of civil war">

            <ImageView
                android:id="@+id/poster_civilwar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/civil_war_poster"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="150dp"
            android:layout_height="200dp"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:stateListAnimator="@animator/poster_click_animator"
            android:contentDescription="A movie poster of civil war">

            <ImageView
                android:id="@+id/poster_nobodytwo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/nobody_two_poster"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="150dp"
            android:layout_height="200dp"
            app:cardCornerRadius="15dp"
            android:clickable="true"
            android:stateListAnimator="@animator/poster_click_animator"
            android:contentDescription="A movie poster of civil war">

            <ImageView
                android:id="@+id/poster_napoleon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/napoleon_poster"/>
        </androidx.cardview.widget.CardView>
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>